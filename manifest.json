{
  "manifest_version": 3,
  "name": "SiteCheck - Technology Detector",
  "version": "2.0.0",
  "description": "Identifies technologies used on websites, along with Geo, DNS, and WHOIS details.",
  "browser_specific_settings": {
    "gecko": {
      "id": "sitecheck@genius-space.org",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SiteCheck",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "categories.json", "technologies.json", "images/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
